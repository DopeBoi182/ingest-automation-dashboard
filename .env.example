PORT=9001
APP_BASE_PATH=
UPLOAD_DIR=/tmp/uploads
DATA_FILE=/tmp/storage.json

EXTERNAL_BASE_URL=http://16.79.175.142:806
EXTRACT_ENDPOINT=/api/v1/jobs/extract
STATUS_ENDPOINT_PREFIX=/api/v1/jobs
QNA_ENDPOINT=/api/v1/chat/qna
REQUEST_TIMEOUT_MS=60000

DEFAULT_PROVIDER=bedrock
DEFAULT_PROMPT=You are an OCR-style extractor. Return only what is visibly present in the document.
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_EMBED=true
DEFAULT_VDB_COLLECTION=docs
DEFAULT_CALLBACK_URL=http://localhost:9001/callback
DEFAULT_VECTOR_GROUP=staging
DEFAULT_KNOWLEDGE_SOURCE=repo-demo
DEFAULT_KNOWLEDGE_TAGS=Oil & Gas Production,Process Engineering
DEFAULT_FORCE=true

# S3 Fetcher integration
Storage__Provider=S3
Storage__S3__Host=ap-south-1.linodeobjects.com
Storage__S3__Region=ap-south-1
Storage__S3__AccessKeyId=
Storage__S3__SecretAccessKey=
Storage__S3__Bucket=
PRESIGN_TTL_SECONDS=900
FORCE_PATH_STYLE=true
USE_HTTPS=true
S3_PUBLIC_BASE_URL=
